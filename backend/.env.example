NODE_ENV=development
PORT=5000
DEBUG=true

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=gmh_user
DATABASE_PASSWORD=secure_password_123
DATABASE_NAME=globalmarkethub
DATABASE_URL=postgresql://gmh_user:secure_password_123@localhost:5432/globalmarkethub

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=gmh_secret_jwt_key_2024_production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_test_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_test_public_key
STRIPE_WEBHOOK_SECRET=whsec_test_webhook_secret

# Email Service
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@globalmarkethub.com

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=optional
AWS_SECRET_ACCESS_KEY=optional
AWS_S3_BUCKET=globalmarkethub-uploads

# Commission Settings
PRODUCT_COMMISSION_RATE=0.05
SERVICE_COMMISSION_RATE=0.15
IMPORT_EXPORT_COMMISSION_RATE=0.05
MIN_PAYOUT=10
PAYOUT_FREQUENCY=weekly

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=gmh_session_secret_key_2024

# Feature Flags
ENABLE_GOOGLE_AUTH=true
ENABLE_PAYPAL=false
ENABLE_ANALYTICS=true
MAINTENANCE_MODE=false

# Twilio
TWILIO_ACCOUNT_SID=optional
TWILIO_AUTH_TOKEN=optional

# Google Maps
GOOGLE_MAPS_API_KEY=optional